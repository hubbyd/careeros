{
  "name": "ai-career-coach",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/backend",
    "packages/web",
    "packages/mobile",
    "packages/shared"
  ],
  "scripts": {
    "backend:dev": "npm run start:dev -w packages/backend",
    "backend:build": "npm run build -w packages/backend",
    "backend:start": "npm run start:prod -w packages/backend",
    "web:dev": "npm run dev -w packages/web",
    "web:build": "npm run build -w packages/web",
    "mobile:dev": "npm run start -w packages/mobile",
    "lint": "npm run lint -w packages/backend && npm run lint -w packages/web",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json}\""
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "@types/node": "^20.11.0"
  },
  "packageManager": "npm@10.2.5"
}
