PORT=3000
HOST=0.0.0.0
NODE_ENV=development

DATABASE_URL="file:./prisma/dev.db"

JWT_SECRET=your-256-bit-secret-key-here-must-be-at-least-32-characters-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

REDIS_HOST=localhost
