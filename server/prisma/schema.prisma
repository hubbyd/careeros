// Prisma Schema for JobSprint

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./jobsprint.db"
}

// 用户
model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  name        String
  avatar      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  todos       Todo[]
  applications Application[]
  studyLogs    StudyLog[]
  questions    Question[]
  assessment   CareerAssessment?
}

// 待办事项
model Todo {
  id        String   @id @default(cuid())
  userId    String
  content   String
  done      Boolean  @default(false)
  date      String   // YYYY-MM-DD
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

// 求职申请
model Application {
  id          String   @id @default(cuid())
  userId      String
  company     String
  position    String
  salary      String?
  status      String   @default("pending") // pending/applied/test/interview/offer/rejected
  priority    String   @default("medium")  // high/medium/low
  deadline    String?
  progress    Int      @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

// 学习记录
model StudyLog {
  id          String   @id @default(cuid())
  userId      String
  date        String   // YYYY-MM-DD
  subject     String   // 学习科目
  minutes     Int      @default(0)
  pomodoroCount Int    @default(0)
  checkedIn   Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

// 面试题库（用户自己的题）
model Question {
  id          String   @id @default(cuid())
  userId      String
  category    String   // javascript/typescript/react/algorithm/system-design/behavior
  question    String
  answer      String?
  difficulty  String   @default("medium") // easy/medium/hard
  mastered    Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
}

// 职业测评结果
model CareerAssessment {
  id            String   @id @default(cuid())
  userId        String   @unique
  major         String
  education     String
  cities        String   // JSON array
  expectedSalary Int
  skills        String   // JSON array
  values        String
  summary       String?  // AI 生成的测评报告
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
